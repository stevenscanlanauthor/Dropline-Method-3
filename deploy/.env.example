# Dropline — environment variables (copy to .env for local API dev)
# Standalone product — separate DB/accounts from AuthorsDrop.

# API server
PORT=3001
DATABASE_URL=postgres://localhost:5432/dropline
JWT_SECRET=change-me-use-openssl-rand-hex-64

# First admin (created on API startup if missing)
ADMIN_INITIAL_EMAIL=you@example.com
ADMIN_INITIAL_PASSWORD=choose-a-strong-password

# Public site URL (CORS + SEO)
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Registration / email
OPEN_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@droplinemethod.com

# App Review demo accounts (created on API startup when set)
APPLE_REVIEW_PASSWORD=
APPLE_REVIEW_EXPIRED_PASSWORD=
ADMIN_BOOTSTRAP_KEY=

# Billing display
BILLING_TRIAL_DAYS=14
BILLING_MAC_PRICE_DISPLAY=39
BILLING_IOS_PRICE_DISPLAY=29

# Web build (optional — empty uses /api proxy in dev)
# VITE_API_URL=
