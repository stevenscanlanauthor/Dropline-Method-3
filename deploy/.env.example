# Dropline — environment variables (copy to .env for local API dev)

# API server
PORT=3001
DATABASE_URL=postgres://localhost:5432/dropline
JWT_SECRET=change-me-use-openssl-rand-hex-64

# First admin (created on API startup if missing)
ADMIN_INITIAL_EMAIL=you@example.com
ADMIN_INITIAL_PASSWORD=choose-a-strong-password

# Public site URL (CORS + SEO)
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Web build (optional — empty uses /api proxy in dev)
# VITE_API_URL=
